<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PeecOneApiRoot Condition="'$(PeecOneApiRoot)' == '' and '$(ONEAPI_ROOT)' != ''">$(ONEAPI_ROOT)</PeecOneApiRoot>
    <PeecOneApiRoot Condition="'$(PeecOneApiRoot)' == ''">D:\Intel\oneAPI</PeecOneApiRoot>

    <PeecMklRoot Condition="'$(PeecMklRoot)' == '' and '$(MKLROOT)' != ''">$(MKLROOT)</PeecMklRoot>
    <PeecMklRoot Condition="'$(PeecMklRoot)' == ''">$(PeecOneApiRoot)\mkl\latest</PeecMklRoot>

    <PeecCompilerRoot Condition="'$(PeecCompilerRoot)' == '' and '$(CMPLR_ROOT)' != ''">$(CMPLR_ROOT)</PeecCompilerRoot>
    <PeecCompilerRoot Condition="'$(PeecCompilerRoot)' == ''">$(PeecOneApiRoot)\compiler\latest</PeecCompilerRoot>

    <PeecMklIncludeDir>$(PeecMklRoot)\include</PeecMklIncludeDir>
    <PeecMklLibDir>$(PeecMklRoot)\lib</PeecMklLibDir>
    <PeecCompilerIncludeDir>$(PeecCompilerRoot)\include</PeecCompilerIncludeDir>
    <PeecCompilerLibDir>$(PeecCompilerRoot)\lib</PeecCompilerLibDir>
  </PropertyGroup>
</Project>
